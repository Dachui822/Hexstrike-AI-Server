# HexStrike AI 环境变量配置

# ============================================================================
# Redis 配置
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Celery 配置
# ============================================================================
# Redis Broker URL (消息代理)
CELERY_BROKER_URL=redis://localhost:6379/0

# Redis Result Backend (结果后端)
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Worker 并发数（每个 Worker 进程的任务并发数）
WORKER_CONCURRENCY=10

# 任务超时控制（秒）
TASK_TIME_LIMIT=3600          # 绝对超时：1 小时
TASK_SOFT_TIME_LIMIT=3300     # 软超时：55 分钟（触发 SoftTimeLimitExceeded）

# 任务确认配置
TASK_ACKS_LATE=true           # 延迟确认（任务完成后才确认，支持重试）
TASK_REJECT_ON_WORKER_LOST=true  # Worker 丢失时拒绝任务（重新入队）

# ============================================================================
# 数据库配置
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=hexstrike
DB_PASSWORD=your_password
DB_NAME=hexstrike

# ============================================================================
# Web 服务配置
# ============================================================================
PORT=8888
FLASK_ENV=production  # development | production

# ============================================================================
# 任务调度配置（已弃用，保留用于向后兼容）
# ============================================================================
# MAX_WORKERS=5  # 已弃用，使用 WORKER_CONCURRENCY 替代
# IDLE_TIMEOUT=300  # 已弃用，由 Celery 超时控制

# ============================================================================
# Celery Worker 启动示例
# ============================================================================
# 开发环境（单 Worker，solo 池）
# python worker.py

# 生产环境（多 Worker，gevent 池）
# celery -A worker.celery worker --loglevel=info --concurrency=10 --pool=gevent -Q hexstrike_default,hexstrike_high_priority,hexstrike_low_priority

# 使用 systemd 管理
# sudo systemctl start hexstrike-worker

# ============================================================================
# Web 服务启动示例
# ============================================================================
# 开发环境
# python run.py

# 生产环境（Gunicorn）
# gunicorn -c gunicorn.conf.py run:app
